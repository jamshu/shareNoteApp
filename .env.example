# Required. Private — server-side only. NEVER prefix with PUBLIC_ (that leaks
# them into the client bundle). Read via $env/dynamic/private in server routes.
#
# IMPORTANT: ODOO_USERNAME / ODOO_API_KEY are the ADMIN account used at signup to
# create a new company + user. This user must be an Odoo administrator (able to
# create res.company and res.users). After signup, each user's own session is
# used for all data — the admin key is never used for reading/writing records.
ODOO_URL=https://your-instance.odoo.com
ODOO_DB=your-database-name
ODOO_USERNAME=admin-username
ODOO_API_KEY=admin-api-key
ODOO_MODEL=x_notes

# Web push (generate once: npx web-push generate-vapid-keys)
# PUBLIC_VAPID_PUBLIC_KEY is safe to expose; the private key is server-only.
PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Optional native push (only when wrapping with Capacitor later)
# FIREBASE_SERVICE_ACCOUNT={"project_id":...}   # Android FCM
# APNS_KEY_ID= APNS_TEAM_ID= APNS_KEY_P8= APNS_BUNDLE_ID=   # iOS

# Optional: point a statically-hosted frontend at a proxy on another origin.
# Empty => same-origin /api/odoo.
# PUBLIC_API_URL=

# Optional, only for sub-path hosting like GitHub Pages.
# PUBLIC_BASE_PATH=/your-repo-name
